<?xml version="1.0" encoding="UTF-8"?>
<testsuites
    name="<%= tag %>"
    tests="<%= junit_suite_tests_count %>"
    failures="<%= junit_suite_failures_count %>"
    errors="<%= junit_suite_errors_count %>"
    skipped="<%= junit_suite_skipped_count %>"
    time="<%= engine_test_steps.sum { _1.execution_time } %>"
    timestamp="<%= timestamp %>">
    <testsuite
        name="<%= tag %>"
        tests="<%= junit_suite_tests_count %>"
        failures="<%= junit_suite_failures_count %>"
        errors="<%= junit_suite_errors_count %>"
        skipped="<%= junit_suite_skipped_count %>"
        time="<%= engine_test_steps.sum { _1.execution_time } %>"
        timestamp="<%= timestamp %>">
        <properties>
            <% run_properties.each do |name, value| %>
                <property name="<%= name %>" value="<%= value %>" />
            <% end %>
        </properties>

        <system-err><%= auto_hck_log %></system-err>

        <% engine_test_steps.each do |test_step| %>
            <testcase name="<%= test_step.name %>" classname="HLKTest" time="<%= test_step.execution_time %>">
                <% unless test_step.last_result.nil? %>
                    <system-out><%= JSON.pretty_generate(test_step.last_result) %></system-out>
                <% end %>
                <% if test_step.status == Models::HLK::TestResultStatus::Failed %>
                    <failure />
                <% elsif test_step.is_skipped %>
                    <skipped />
                <% end %>
            </testcase>
        <% end %>

        <testcase name="AutoHCK session" classname="AutoHCK" time="0">
            <% if autohck_project_status == :error %>
                <error message="AutoHCK framework error" />
            <% elsif autohck_project_status == :failed %>
                <failure message="One or more tests failed" />
            <% elsif autohck_project_status == :canceled %>
                <skipped message="Session canceled" />
            <% elsif autohck_project_status == :running %>
                <skipped message="Use skipped status to show that the project did not complete, but the test steps that ran should still be considered valid results." />
            <% end %>
        </testcase>
    </testsuite>
</testsuites>
